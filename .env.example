APP_NAME="Traffic Violation Record System"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stderr
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# --- DO Managed PostgreSQL ---
DB_CONNECTION=pgsql
DB_HOST=your-do-db-host.db.ondigitalocean.com
DB_PORT=25060
DB_DATABASE=tvrs
DB_USERNAME=tvrs_user
DB_PASSWORD=<your-db-password>
DB_SSLMODE=require

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
UPLOADS_DISK=s3
QUEUE_CONNECTION=sync

CACHE_STORE=file

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

DEFAULT_ADMIN_PASSWORD=

# --- DO Spaces (S3-compatible) ---
# Get these from: DO Dashboard → Spaces → Manage Keys
AWS_ACCESS_KEY_ID=<spaces-access-key-id>
AWS_SECRET_ACCESS_KEY=<spaces-secret-key>
AWS_DEFAULT_REGION=sgp1
AWS_BUCKET=tvrs-uploads
AWS_ENDPOINT=https://sgp1.digitaloceanspaces.com
AWS_URL=https://tvrs-uploads.sgp1.digitaloceanspaces.com
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
